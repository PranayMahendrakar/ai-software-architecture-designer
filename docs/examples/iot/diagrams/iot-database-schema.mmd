        TIMESTAMP created_at
    }

    ORDERS {
        UUID id PK
        UUID user_id FK
        VARCHAR(50) status
        DECIMAL(10,2) total_amount
        VARCHAR(255) payment_intent_id
        JSONB shipping_address
        TIMESTAMP created_at
        TIMESTAMP updated_at
    }

