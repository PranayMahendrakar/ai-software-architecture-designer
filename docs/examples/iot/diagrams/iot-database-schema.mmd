erDiagram
    USERS {
        UUID id PK
        VARCHAR(255) email
        VARCHAR(255) password_hash
        VARCHAR(100) full_name
        VARCHAR(50) role
        BOOLEAN is_active
        TIMESTAMP created_at
        TIMESTAMP updated_at
    }

    SESSIONS {
        UUID id PK
        UUID user_id FK
        VARCHAR(512) token_hash
        TIMESTAMP expires_at
